PORT=3000
NODE_ENV=production

DATABASE_URL=postgresql://user:password@host:5432/dbname

WAVE_API_KEY=your_wave_api_key_here

BOOKKEEPER_API_KEY=your_n8n_bookkeeper_api_key_here

SESSION_SECRET=a_long_random_string_at_least_32_chars

